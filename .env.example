EXPO_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon

# Gemini — usar apenas em Edge Functions (não expor no cliente)
GEMINI_API_KEY=

# URL: use apenas https://SEU-ID.supabase.co (sem /rest/v1/ no final)

# Windows: se aparecer erro de certificado SSL, os scripts npm ja usam NODE_OPTIONS=--use-system-ca.
# Para rodar manualmente no PowerShell:
# $env:NODE_OPTIONS="--use-system-ca"; npm run web
